# Copy this file to Railway Variables or a local .env file. Never commit real values.
NODE_ENV=production
PORT=3000

# Railway persistent storage
APP_DATA_DIR=/data
DATABASE_PATH=/data/database.db
UPLOAD_DIR=/data/uploads
BACKUP_DIR=/data/backups

# Bosta integration
BOSTA_API_KEY=put_your_bosta_key_here
BOSTA_BASE_URL=https://app.bosta.co/api/v2
BOSTA_WEBHOOK_AUTH=change_this_secret

# Sessions
SESSION_TTL_HOURS=12
SESSION_IDLE_SECONDS=180
LOCATION_TRACKING_ENABLED=1
